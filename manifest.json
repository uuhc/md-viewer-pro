{
  "manifest_version": 3,
  "name": "MD Viewer Pro",
  "version": "1.1.4",
  "description": "Auto-preview Markdown files with file tree, TOC navigation, code highlight & HTML export",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "file:///*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "file:///*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "MD Viewer Pro"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "viewer.html",
        "viewer.js",
        "assets/*"
      ],
      "matches": [
        "file:///*"
      ]
    }
  ]
}
